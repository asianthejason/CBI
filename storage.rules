rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /captains/{leagueId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "admin@cbi.com";
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
